{
  "name": "astro-blog",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "deploy": "astro build && bunx wrangler deploy",
    "build": "astro check && astro build",
    "preview": "bun run build && bun wrangler dev",
    "db:init": "bun wrangler d1 execute astro-blog-db --local --file=functions/schema.sql",
    "preview:remote": "astro build && wrangler dev --remote",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "0.9.7",
    "@astrojs/cloudflare": "13.1.1",
    "@astrojs/mdx": "5.0.0",
    "@astrojs/sitemap": "3.7.1",
    "@astrojs/tailwind": "^6.0.2",
    "@tailwindcss/typography": "~0.5.19",
    "astro": "6.0.4",
    "marked": "^17.0.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "wrangler": "^4.79.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1"
  }
}
