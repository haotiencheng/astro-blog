---
const GA_ID = import.meta.env.PUBLIC_GA_ID;
const CF_TOKEN = import.meta.env.PUBLIC_CF_TOKEN;
const POSTHOG_KEY = import.meta.env.PUBLIC_POSTHOG_KEY;
const POSTHOG_HOST = import.meta.env.PUBLIC_POSTHOG_HOST;
const UMAMI_ID = import.meta.env.PUBLIC_UMAMI_ID;
---

<!-- Google Analytics -->
<script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
<script define:vars={{ GA_ID }}>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', GA_ID);
</script>

<!-- Cloudflare Web Analytics -->
<script 
  defer 
  src='https://static.cloudflareinsights.com/beacon.min.js' 
  define:vars={{ CF_TOKEN }}
  data-cf-beacon={`{"token": "${CF_TOKEN}"}`}
></script>

<!-- PostHog -->
<script define:vars={{ POSTHOG_KEY, POSTHOG_HOST }}>
