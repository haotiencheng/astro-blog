---
/**
 * Bookmark card — auto-fetches OG metadata at build time.
 *
 * Minimal usage (all metadata fetched automatically):
 *   <Bookmark url="https://t.me/BotFather" />
 *
 * Override any field manually:
 *   <Bookmark url="https://t.me/BotFather" title="BotFather" caption="點擊使用" />
 *
 * Only `url` is required.
 */

interface Props {
  url: string;
  title?: string;
  description?: string;
  icon?: string;
  author?: string;
  thumbnail?: string;
  caption?: string;
}

const { url, caption, ...overrides } = Astro.props;

// ── OG helpers (build-time only) ──────────────────────────────────────────

function metaVal(html: string, property: string, nameAttr?: string): string | null {
  const targets = [`property=["']${property}["']`];
  if (nameAttr) targets.push(`name=["']${nameAttr}["']`);
  for (const target of targets) {
    let m = html.match(new RegExp(`<meta[^>]+content=["']([^"']*?)["'][^>]+${target}`, 'i'));
    if (m) return decode(m[1]);
    m = html.match(new RegExp(`<meta[^>]+${target}[^>]+content=["']([^"']*?)["']`, 'i'));
    if (m) return decode(m[1]);
  }
  return null;
}

function linkHref(html: string, rel: string): string | null {
  let m = html.match(new RegExp(`<link[^>]+rel=["']${rel}["'][^>]+href=["']([^"']+)["']`, 'i'));
  if (m) return m[1];
  m = html.match(new RegExp(`<link[^>]+href=["']([^"']+)["'][^>]+rel=["']${rel}["']`, 'i'));
  return m ? m[1] : null;
}

function decode(s: string): string {
  return s.replace(/&amp;/g,'&').replace(/&quot;/g,'"').replace(/&#39;/g,"'")
          .replace(/&lt;/g,'<').replace(/&gt;/g,'>').trim();
}

function resolve(href: string | null, base: string): string | null {
  if (!href) return null;
  try { return new URL(href, base).href; } catch { return href; }
}

// ── Fetch OG data (skipped if all props already provided) ─────────────────

let fetched: Partial<Props> = {};

if (!overrides.title) {
  try {
    const res = await fetch(url, {
      headers: { 'User-Agent': 'Mozilla/5.0 (compatible; bot/1.0)' },
      signal: AbortSignal.timeout(8000),
    });
    const html = await res.text();
    const base = res.url;

    fetched.title =
      metaVal(html, 'og:title') ??
      html.match(/<title[^>]*>([^<]+)<\/title>/i)?.[1]?.trim() ??
      url;

    fetched.description =
      metaVal(html, 'og:description') ??
      metaVal(html, '', 'description') ??
      undefined;

    fetched.thumbnail =
      resolve(metaVal(html, 'og:image') ?? metaVal(html, 'og:image:url'), base) ??
      undefined;

    fetched.author =
      metaVal(html, 'og:site_name') ??
      metaVal(html, '', 'application-name') ??
      undefined;

    fetched.icon =
      resolve(
        linkHref(html, 'apple-touch-icon') ??
        linkHref(html, 'icon') ??
        linkHref(html, 'shortcut icon') ??
        '/favicon.ico',
        base,
      ) ?? undefined;

  } catch (e) {
    // Build continues — card renders with whatever is available
    fetched.title = fetched.title ?? url;
  }
}

// Manual props take precedence over fetched data
const { title, description, icon, author, thumbnail } = { ...fetched, ...overrides };

// Fallback author from hostname
const hostname = (() => {
  try { return new URL(url).hostname.replace(/^www\./, ''); } catch { return ''; }
})();
---

<figure class:list={['kg-card', 'kg-bookmark-card', caption && 'kg-card-hascaption']}>
  <a class="kg-bookmark-container" href={url} target="_blank" rel="noopener noreferrer">
    <div class="kg-bookmark-content">
      <div class="kg-bookmark-title">{title}</div>
      {description && (
        <div class="kg-bookmark-description">{description}</div>
      )}
      <div class="kg-bookmark-metadata">
        {icon && (
          <img class="kg-bookmark-icon" src={icon} alt="" loading="lazy" />
        )}
        <span class="kg-bookmark-author">{author ?? hostname}</span>
      </div>
    </div>
    {thumbnail && (
      <div class="kg-bookmark-thumbnail">
        <img src={thumbnail} alt="" onerror="this.style.display='none'" loading="lazy" />
      </div>
    )}
  </a>
  {caption && (
    <figcaption>
      <p><span style="white-space: pre-wrap;">{caption}</span></p>
    </figcaption>
  )}
</figure>
