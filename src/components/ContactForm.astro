---
interface Props {
  lang: "zh-tw" | "en";
}

const { lang } = Astro.props;
const isEn = lang === "en";

const t = {
  title: isEn ? "Get in Touch" : "與我聯繫",
  subtitle: isEn
    ? "Need help with AI automation, workflow optimization, or building with AI tools? Leave your info and question below — I'll get back to you by email within a day."
    : "需要 AI 自動化、工作流程優化，或是用 AI 工具打造產品方面的協助？ 留下你的資訊和問題，我會在一天內透過 email 回覆你。",
  name: isEn ? "Name" : "姓名",
  namePlaceholder: isEn ? "Your name" : "你的名字",
  nameError: isEn ? "Please enter your name" : "請輸入姓名",
  email: "Email",
  emailPlaceholder: "you@example.com",
  emailEmptyError: isEn ? "Please enter your email" : "請輸入 email 地址",
  emailInvalidError: isEn ? "Please enter a valid email address" : "請輸入有效的 email 地址",
  message: isEn ? "How can I help?" : "有什麼我能幫忙的？",
  messagePlaceholder: isEn
    ? "Describe your project or question — e.g. automating social media, building AI workflows, integrating Claude into your app..."
    : "描述你的專案或問題 — 例如自動化社群媒體發文、建立 AI 工作流程、將 Claude 整合到你的應用中...",
  messageError: isEn ? "Please describe your question or project" : "請輸入你的問題或需求",
  submit: isEn ? "Send Message" : "送出訊息",
  sending: isEn ? "Sending..." : "送出中...",
  success: isEn ? "Thanks for reaching out! I'll get back to you within a day." : "感謝你的來信！我會在一天內回覆你。",
  genericError: isEn ? "Failed to send. Please try again." : "送出失敗，請再試一次。",
};

const inputClass = "w-full rounded-lg border border-gray-300 px-4 py-2.5 text-gray-900 focus:border-gray-900 focus:ring-1 focus:ring-gray-900 outline-none transition-colors";
---

<div class="mx-auto max-w-3xl px-4 py-12">
  <h1 class="text-3xl font-bold mb-2">{t.title}</h1>
  <p class="text-gray-600 mb-8">{t.subtitle}</p>

  <form id="contact-form" class="space-y-5" novalidate
    data-sending={t.sending}
    data-default={t.submit}
    data-email-empty={t.emailEmptyError}
    data-email-invalid={t.emailInvalidError}
    data-generic-error={t.genericError}
  >
    <div>
      <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
        {t.name} <span class="text-red-500">*</span>
      </label>
      <input type="text" id="name" name="name" required class={inputClass} placeholder={t.namePlaceholder} />
      <p class="field-error mt-1 text-sm text-red-600 hidden" data-field="name">{t.nameError}</p>
    </div>

    <div>
      <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
        {t.email} <span class="text-red-500">*</span>
      </label>
      <input type="email" id="email" name="email" required class={inputClass} placeholder={t.emailPlaceholder} />
      <p class="field-error mt-1 text-sm text-red-600 hidden" data-field="email">{t.emailInvalidError}</p>
    </div>

    <div>
      <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
        {t.message} <span class="text-red-500">*</span>
      </label>
      <textarea id="message" name="message" required rows="5" class={`${inputClass} resize-y`} placeholder={t.messagePlaceholder}></textarea>
      <p class="field-error mt-1 text-sm text-red-600 hidden" data-field="message">{t.messageError}</p>
    </div>

    <button
      type="submit"
      class="inline-flex items-center gap-2 rounded-lg bg-gray-900 px-6 py-2.5 text-sm font-medium text-white hover:bg-gray-800 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
    >
      <span id="btn-text">{t.submit}</span>
      <svg id="btn-spinner" class="hidden animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
    </button>
  </form>

  <div id="success-msg" class="hidden mt-6 rounded-lg bg-green-50 border border-green-200 p-4 text-green-800">
    {t.success}
  </div>

  <div id="error-msg" class="hidden mt-6 rounded-lg bg-red-50 border border-red-200 p-4 text-red-800">
  </div>

  <div class="mt-12 pt-8 border-t border-gray-200">
    <p class="text-sm text-gray-500 mb-4">{isEn ? "Or find me on social media" : "也可以在社群媒體上找到我"}</p>
    <div class="flex items-center gap-4">
      <!-- X (Twitter) -->
      <a href="https://x.com/projectstain" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-900 transition-colors" aria-label="X (Twitter)">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
      <!-- Threads -->
      <a href="https://threads.net/@project.stain" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-900 transition-colors" aria-label="Threads">
        <svg class="w-5 h-5" viewBox="0 0 192 192" fill="currentColor">
          <path d="M141.537 88.988a66.667 66.667 0 0 0-2.518-1.143c-1.482-27.307-16.403-42.94-41.457-43.1h-.34c-14.986 0-27.449 6.396-35.12 18.035l13.732 9.417c5.731-8.704 14.709-10.57 21.388-10.57h.229c8.249.053 14.474 2.452 18.503 7.129 2.932 3.405 4.893 8.111 5.864 14.05-7.314-1.243-15.224-1.626-23.68-1.14-23.82 1.371-39.134 15.264-38.105 34.568.522 9.792 5.4 18.216 13.735 23.719 7.047 4.652 16.124 6.927 25.557 6.412 12.458-.683 22.231-5.436 29.049-14.127 5.178-6.6 8.453-15.153 9.899-25.93 5.937 3.583 10.337 8.298 12.767 13.966 4.132 9.635 4.373 25.468-8.546 38.376-11.319 11.308-24.925 16.2-45.488 16.352-22.808-.169-40.06-7.484-51.278-21.742C35.54 124.667 29.974 106.882 29.755 84c.219-22.882 5.785-40.667 16.528-52.833 11.218-14.258 28.47-21.573 51.278-21.742 22.95.17 40.56 7.52 52.345 21.847 5.79 7.07 10.145 15.987 13.02 26.367l16.146-4.314c-3.44-12.68-8.853-23.606-16.234-32.612C147.036 8.013 125.202-1.252 96.842-1.48h-.405C68.15-1.252 46.622 8.06 32.23 26.68 19.38 43.2 12.726 66.39 12.5 95.998v.005c.226 29.61 6.88 52.8 19.73 69.317 14.392 18.622 35.92 27.934 63.957 28.16h.405c24.957-.198 42.504-6.713 56.988-21.186 18.976-18.962 18.413-42.713 12.152-57.248-4.502-10.493-13.232-18.99-24.195-24.058Z"/>
        </svg>
      </a>
      <!-- Instagram -->
      <a href="https://www.instagram.com/project.stain/" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-900 transition-colors" aria-label="Instagram">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
      </a>
      <!-- Facebook -->
      <a href="https://www.facebook.com/profile.php?id=61577550411957" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-900 transition-colors" aria-label="Facebook">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
      </a>
      <!-- LinkedIn -->
      <a href="https://www.linkedin.com/in/haotiencheng/" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-900 transition-colors" aria-label="LinkedIn">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <!-- Telegram -->
      <a href="https://t.me/projectstain" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-900 transition-colors" aria-label="Telegram">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
        </svg>
      </a>
    </div>
  </div>
</div>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const btnText = document.getElementById("btn-text")!;
  const btnSpinner = document.getElementById("btn-spinner")!;
  const successMsg = document.getElementById("success-msg")!;
  const errorMsg = document.getElementById("error-msg")!;
  const submitBtn = form.querySelector("button[type=submit]") as HTMLButtonElement;

  const sendingText = form.dataset.sending!;
  const defaultText = form.dataset.default!;
  const emailEmptyMsg = form.dataset.emailEmpty!;
  const emailInvalidMsg = form.dataset.emailInvalid!;
  const genericError = form.dataset.genericError!;
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  const errorBorder = "border-red-500 focus:border-red-500 focus:ring-red-500";
  const normalBorder = "border-gray-300 focus:border-gray-900 focus:ring-gray-900";

  function setFieldError(field: HTMLInputElement | HTMLTextAreaElement, show: boolean, msg?: string) {
    const errorEl = form.querySelector(`.field-error[data-field="${field.name}"]`) as HTMLElement;
    if (show) {
      field.classList.remove(...normalBorder.split(" "));
      field.classList.add(...errorBorder.split(" "));
      if (msg) errorEl.textContent = msg;
      errorEl.classList.remove("hidden");
    } else {
      field.classList.remove(...errorBorder.split(" "));
      field.classList.add(...normalBorder.split(" "));
      errorEl.classList.add("hidden");
    }
  }

  function validate(): boolean {
    const nameEl = form.elements.namedItem("name") as HTMLInputElement;
    const emailEl = form.elements.namedItem("email") as HTMLInputElement;
    const messageEl = form.elements.namedItem("message") as HTMLTextAreaElement;
    let valid = true;

    if (!nameEl.value.trim()) {
      setFieldError(nameEl, true);
      valid = false;
    } else {
      setFieldError(nameEl, false);
    }

    if (!emailEl.value.trim()) {
      setFieldError(emailEl, true, emailEmptyMsg);
      valid = false;
    } else if (!emailRegex.test(emailEl.value.trim())) {
      setFieldError(emailEl, true, emailInvalidMsg);
      valid = false;
    } else {
      setFieldError(emailEl, false);
    }

    if (!messageEl.value.trim()) {
      setFieldError(messageEl, true);
      valid = false;
    } else {
      setFieldError(messageEl, false);
    }

    return valid;
  }

  for (const field of [form.elements.namedItem("name"), form.elements.namedItem("email"), form.elements.namedItem("message")] as (HTMLInputElement | HTMLTextAreaElement)[]) {
    field.addEventListener("input", () => setFieldError(field, false));
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    errorMsg.classList.add("hidden");
    successMsg.classList.add("hidden");

    if (!validate()) return;

    submitBtn.disabled = true;
    btnText.textContent = sendingText;
    btnSpinner.classList.remove("hidden");

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          name: (form.elements.namedItem("name") as HTMLInputElement).value,
          email: (form.elements.namedItem("email") as HTMLInputElement).value,
          message: (form.elements.namedItem("message") as HTMLTextAreaElement).value,
        }),
      });

      const data = await res.json() as { error?: string };

      if (!res.ok) {
        throw new Error(data.error || "Something went wrong");
      }

      form.reset();
      successMsg.classList.remove("hidden");
      form.classList.add("hidden");
    } catch (err: any) {
      errorMsg.textContent = err.message || genericError;
      errorMsg.classList.remove("hidden");
    } finally {
      submitBtn.disabled = false;
      btnText.textContent = defaultText;
      btnSpinner.classList.add("hidden");
    }
  });
</script>
