---
interface Props {
  title: string;
  slug: string;
  excerpt: string;
  featureImage: string | null;
  publishedAt: string;
  tags: { name: string; slug: string }[];
  lang: "zh-tw" | "en";
  featured?: boolean;
}

const { title, slug, excerpt, featureImage, publishedAt, tags, lang, featured } = Astro.props;

const url = lang === "en" ? `/en/${slug}/` : `/zh-tw/${slug}/`;
const date = new Date(publishedAt);
const formattedDate = date.toLocaleDateString(lang === "zh-tw" ? "zh-TW" : "en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const tagSlugs = tags.map((t) => t.slug).join(",");

// Use thumbnail version for card grid (480px wide WebP)
function getThumbSrc(src: string | null): string | null {
  if (!src) return null;
  // /images/ghost/2025/03/photo.webp -> /images/ghost/thumb/2025/03/photo.webp
  const match = src.match(/^\/images\/ghost\/(\d{4}\/.*)$/);
  if (match) return `/images/ghost/thumb/${match[1]}`;
  return src;
}

const thumbSrc = getThumbSrc(featureImage);
---

<a
  href={url}
  class="post-card group block"
  data-tags={tagSlugs}
>
  <article>
    <div class="card-image">
      {
        featureImage ? (
          <img
            src={thumbSrc || featureImage}
            srcset={thumbSrc ? `${thumbSrc} 480w, ${featureImage} 960w` : undefined}
            sizes="(max-width: 640px) 100vw, 480px"
            alt={title}
            width="480"
            height="270"
            loading="lazy"
            decoding="async"
            onload="this.classList.add('loaded')"
          />
        ) : (
          <div class="placeholder">
            <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="48" height="48" rx="8" fill="#f3f4f6"/>
              <path d="M16 32l6-8 4 5.33L30 24l6 8H16z" fill="#d1d5db"/>
              <circle cx="20" cy="20" r="3" fill="#d1d5db"/>
            </svg>
          </div>
        )
      }
      {featured && <span class="featured-badge">{lang === "en" ? "Featured" : "精選"}</span>}
    </div>
    <div class="card-body">
      <div class="card-meta">
        <time datetime={publishedAt}>{formattedDate}</time>
        {tags.length > 0 && <span class="meta-sep">&middot;</span>}
        {tags.slice(0, 2).map((tag) => <span class="tag">{tag.name}</span>)}
      </div>
      <h2 class="card-title">{title}</h2>
      <p class="card-excerpt">{excerpt}</p>
    </div>
  </article>
</a>

<style>
  .post-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 0.75rem;
    overflow: hidden;
    background: #fff;
    border: 1px solid #f0f0f0;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .card-image {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #f9fafb;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .card-image img.loaded {
    opacity: 1;
  }

  .post-card:hover .card-image img.loaded {
    transform: scale(1.03);
  }

  .card-image .placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f9fafb;
  }

  .card-image .placeholder svg {
    width: 48px;
    height: 48px;
    opacity: 0.5;
  }

  .featured-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 0.25rem;
  }

  .card-body {
    padding: 1rem 1.25rem 1.25rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: #9ca3af;
    margin-bottom: 0.5rem;
  }

  .meta-sep {
    color: #d1d5db;
  }

  .tag {
    color: #6b7280;
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 650;
    line-height: 1.4;
    margin: 0 0 0.4rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.15s;
  }

  .post-card:hover .card-title {
    color: #2563eb;
  }

  .card-excerpt {
    font-size: 0.85rem;
    line-height: 1.6;
    color: #6b7280;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
