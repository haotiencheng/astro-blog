---
import { Image } from "astro:assets";
import { getThumbSrc } from "../utils/postHelpers";
import { resolvePostImage } from "../utils/images";
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"posts">[];
  lang: "zh-tw" | "en";
}

const { posts, lang } = Astro.props;

function postUrl(slug: string) {
  return `/${lang}/${slug}/`;
}
---

{posts.length > 0 && (
  <section class="related-section">
    <h2 class="related-heading">{lang === "en" ? "Related Posts" : "相關文章"}</h2>
    <div class="related-grid">
      {posts.map((post) => {
        const img = post.data.feature_image;
        const imgMeta = resolvePostImage(img);
        const tag = post.data.tags[0];
        return (
          <a href={postUrl(post.data.slug)} class="related-card">
            <div class="related-img-wrap">
              {imgMeta ? (
                <Image
                  src={imgMeta}
                  alt={post.data.title}
                  width={320}
                  height={180}
                  widths={[160, 320]}
                  sizes="(max-width: 640px) 100vw, 320px"
                  loading="lazy"
                  decoding="async"
                />
              ) : img ? (
                <img
                  src={getThumbSrc(img) || img}
                  alt={post.data.title}
                  width="320"
                  height="180"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="related-img-empty" />
              )}
            </div>
            <div class="related-body">
              {tag && <span class="related-tag">{tag.name}</span>}
              <h3 class="related-title">{post.data.title}</h3>
            </div>
          </a>
        );
      })}
    </div>
  </section>
)}

<style>
  .related-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #e5e7eb;
  }

  .related-heading {
    font-size: 1.15rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 1.25rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .related-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid #f0f0f0;
    background: #fff;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .related-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
  }

  .related-img-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #f3f4f6;
  }

  .related-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }

  .related-card:hover .related-img-wrap img {
    transform: scale(1.04);
  }

  .related-img-empty {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
  }

  .related-body {
    padding: 0.75rem 0.875rem;
  }

  .related-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: #9ca3af;
    margin-bottom: 0.25rem;
  }

  .related-title {
    font-size: 0.85rem;
    font-weight: 650;
    line-height: 1.4;
    margin: 0;
    color: #111827;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.15s;
  }

  .related-card:hover .related-title {
    color: #2563eb;
  }
</style>
