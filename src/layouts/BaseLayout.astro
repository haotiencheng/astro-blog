---
import Analytics from '../components/Analytics.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string | null;
  lang?: "zh-tw" | "en";
  canonicalUrl?: string;
  alternateUrl?: string;
  alternateLang?: string;
}

const {
  title,
  description = "ReallyNiceDay - Indie Developer | Dancer | NTU FIN graduate",
  ogImage,
  lang = "zh-tw",
  canonicalUrl,
  alternateUrl,
  alternateLang,
} = Astro.props;

const siteUrl = "https://reallyniceday.com";
const fullOgImage = ogImage
  ? ogImage.startsWith("http")
    ? ogImage
    : `${siteUrl}${ogImage}`
  : `${siteUrl}/images/ghost/icon/R0000314-6.JPG`;
const htmlLang = lang === "zh-tw" ? "zh-Hant-TW" : "en";
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:locale" content={lang === "zh-tw" ? "zh_TW" : "en_US"} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {
      alternateUrl && alternateLang && (
        <link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
      )
    }
    <Analytics />
  </head>
  <body class="bg-white text-gray-900 antialiased">
    <nav class="border-b border-gray-200">
      <div class="mx-auto max-w-3xl px-4 py-4 flex items-center justify-between">
        <a href={lang === "en" ? "/en/" : "/"} class="hover:opacity-80 transition-opacity">
          <img src="/images/logo.webp" alt="ReallyNiceDay" width="224" height="125" class="h-9 w-auto" />
        </a>
        <div class="flex items-center gap-4 text-sm">
          <a href={lang === "en" ? "/en/" : "/"} class="hover:text-gray-600 transition-colors">
            {lang === "en" ? "Home" : "首頁"}
          </a>
          <a href="/about/" class="hover:text-gray-600 transition-colors">
            {lang === "en" ? "About" : "關於"}
          </a>
          <a href="https://www.projectstain.dev" class="hover:text-gray-600 transition-colors">
            {lang === "en" ? "Projects" : "專案"}
          </a>
          <a
            href={lang === "en" ? "/" : "/en/"}
            class="px-2 py-1 rounded border border-gray-300 hover:bg-gray-100 transition-colors"
          >
            {lang === "en" ? "中文" : "EN"}
          </a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="border-t border-gray-200 mt-16">
      <div class="mx-auto max-w-3xl px-4 py-8 text-sm text-gray-500">
        <div class="flex flex-col sm:flex-row items-center justify-center gap-1 sm:gap-3">
          <span>&copy; {new Date().getFullYear()} ReallyNiceDay. Built with Astro.</span>
          <span class="hidden sm:inline text-gray-300">·</span>
          <a href="mailto:hello@reallyniceday.com" class="flex items-center gap-1 hover:text-gray-700 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            hello@reallyniceday.com
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* Ghost Bookmark Cards */
  .kg-bookmark-card {
    margin: 1.5em 0;
    width: 100%;
  }

  .kg-bookmark-container {
    display: flex;
    text-decoration: none;
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    overflow: hidden;
    color: inherit;
    transition: box-shadow 0.2s;
  }

  .kg-bookmark-container:hover {
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.08);
  }

  .kg-bookmark-content {
    flex: 1;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
  }

  .kg-bookmark-title {
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 0.35em;
  }

  .kg-bookmark-description {
    font-size: 0.8rem;
    color: #6b7280;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0.5em;
  }

  .kg-bookmark-metadata {
    display: flex;
    align-items: center;
    gap: 0.4em;
    font-size: 0.75rem;
    color: #9ca3af;
  }

  .kg-bookmark-icon {
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 0.25rem;
    object-fit: cover;
  }

  .kg-bookmark-thumbnail {
    flex-shrink: 0;
    width: 160px;
    position: relative;
  }

  .kg-bookmark-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
    margin: 0;
  }

  @media (max-width: 640px) {
    .kg-bookmark-container {
      flex-direction: column-reverse;
    }
    .kg-bookmark-thumbnail {
      width: 100%;
      height: 160px;
    }
  }

  /* Ghost Callout Cards */
  .kg-callout-card {
    display: flex;
    gap: 0.75rem;
    padding: 1.25rem;
    border-radius: 0.5rem;
    margin: 1.5em 0;
    background: #f3f4f6;
  }

  .kg-callout-card-blue {
    background: #eff6ff;
  }

  .kg-callout-card-grey {
    background: #f3f4f6;
  }

  .kg-callout-emoji {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .kg-callout-text {
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* Ghost Image Cards */
  .kg-image-card {
    margin: 1.5em 0;
    max-width: 100%;
    overflow: hidden;
  }

  .kg-image-card img,
  .kg-image {
    border-radius: 0.5rem;
    max-width: 100%;
    height: auto;
    display: block;
  }

  .kg-image-card figcaption {
    text-align: center;
    font-size: 0.8rem;
    color: #9ca3af;
    margin-top: 0.5em;
  }

  /* Ghost Embed Cards (YouTube, etc.) */
  .kg-embed-card {
    margin: 1.5em 0;
    position: relative;
  }

  .kg-embed-card iframe {
    width: 100% !important;
    height: auto !important;
    aspect-ratio: 16 / 9;
    border-radius: 0.5rem;
    border: none;
  }

  .kg-embed-card figcaption {
    text-align: center;
    font-size: 0.8rem;
    color: #9ca3af;
    margin-top: 0.5em;
  }

  /* Ghost Video Cards */
  .kg-video-card {
    margin: 1.5em 0;
  }

  .kg-video-container {
    position: relative;
    width: 100%;
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .kg-video-container video {
    width: 100%;
    display: block;
  }

  /* Responsive heading sizes inside post content */
  .gh-content :where(h1) { font-size: 1.6rem; }
  .gh-content :where(h2) { font-size: 1.3rem; }
  .gh-content :where(h3) { font-size: 1.1rem; }

  @media (min-width: 768px) {
    .gh-content :where(h1) { font-size: 2.25rem; }
    .gh-content :where(h2) { font-size: 1.75rem; }
    .gh-content :where(h3) { font-size: 1.375rem; }
  }

  /* Prevent long URLs/strings from breaking mobile layout */
  .prose {
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .prose :where(a) {
    overflow-wrap: break-word;
    word-break: break-all;
  }

  /* Inline code */
  .prose :where(code):not(:where(pre code)) {
    background: #f3f4f6;
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
    font-size: 0.85em;
    font-weight: 400;
  }

  .prose :where(code):not(:where(pre code))::before,
  .prose :where(code):not(:where(pre code))::after {
    content: none;
  }

  /* Ghost Blockquote Alt */
  .kg-blockquote-alt {
    border-left: 3px solid #d1d5db;
    padding-left: 1rem;
    font-style: italic;
    color: #6b7280;
  }
</style>
