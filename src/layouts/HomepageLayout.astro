---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import { getThumbSrc, getReadingTime } from "../utils/postHelpers";
import type { Lang, HomepageUI } from "../i18n/homepage";

interface Props {
  lang: Lang;
  carouselPosts: CollectionEntry<"posts">[];
  allPosts: CollectionEntry<"posts">[];
  allTags: { slug: string; name: string }[];
  t: HomepageUI;
}

const { lang, carouselPosts, allPosts, allTags, t } = Astro.props;

function postUrl(slug: string) {
  return `/${lang}/${slug}/`;
}

function formatCarouselDate(iso: string) {
  return new Date(iso).toLocaleDateString(t.dateLocale, {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<BaseLayout title="ReallyNiceDay" lang={lang}>

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <p class="hero-label">Indie Developer &middot; Dancer &middot; NTU FIN</p>
    <h1 class="hero-title">ReallyNiceDay</h1>
    <p class="hero-sub">{t.heroSub}</p>
  </section>

  <!-- ═══ CAROUSEL ═══ -->
  <section class="carousel-section" aria-label={t.carouselAriaLabel}>
    <div class="carousel-wrapper">
      <div class="carousel-track" id="carousel-track">
        {carouselPosts.map((post, i) => {
          const img = post.data.feature_image;
          const thumb = getThumbSrc(img);
          const tag = post.data.tags[0];
          return (
            <div class="carousel-slide">
              <a href={postUrl(post.data.slug)} class="slide-link">
                <div class="slide-img-wrap">
                  {img ? (
                    <img
                      src={thumb || img}
                      srcset={thumb ? `${thumb} 480w, ${img} 960w` : undefined}
                      sizes="(min-width:768px) 33vw, 100vw"
                      alt={post.data.title}
                      class="slide-img"
                      loading={i === 0 ? "eager" : "lazy"}
                      decoding="async"
                    />
                  ) : (
                    <div class="slide-img-placeholder" />
                  )}
                </div>
                <div class="slide-content">
                  {tag && <span class="slide-tag">{tag.name}</span>}
                  <h2 class="slide-title">{post.data.title}</h2>
                  <p class="slide-excerpt">{post.data.excerpt}</p>
                  <time class="slide-date">{formatCarouselDate(post.data.published_at)}</time>
                </div>
              </a>
            </div>
          );
        })}
      </div>

      {carouselPosts.length > 1 && (
        <div class="carousel-controls" id="carousel-controls">
          <button class="carousel-btn" id="carousel-prev" aria-label={t.prevLabel}>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <div class="carousel-dots">
            {carouselPosts.map((_, i) => (
              <button class={`dot${i === 0 ? " active" : ""}`} data-dot={i} aria-label={t.dotAriaLabel(i + 1)} />
            ))}
          </div>
          <button class="carousel-btn" id="carousel-next" aria-label={t.nextLabel}>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
      )}
    </div>
  </section>

  <!-- ═══ TAG FILTER ═══ -->
  <div class="filter-wrap">
    <div class="filter-bar">
      <button class="filter-pill active" data-filter="all">{t.filterAll}</button>
      {allTags.map((tag) => (
        <button class="filter-pill" data-filter={tag.slug}>{tag.name}</button>
      ))}
    </div>
  </div>

  <!-- ═══ COMPACT LIST ═══ -->
  <section class="post-list-section">
    <div class="post-list" id="post-list">
      {allPosts.map((post) => {
        const img = post.data.feature_image;
        const thumb = getThumbSrc(img);
        const tag = post.data.tags[0];
        const tagSlugs = post.data.tags.map((t) => t.slug).join(",");
        const d = new Date(post.data.published_at);
        const readingTime = getReadingTime(post.data.slug, lang);
        return (
          <a href={postUrl(post.data.slug)} class="post-row" data-tags={tagSlugs}>
            <div class="row-date">
              <span class="row-day">{d.getDate()}</span>
              <span class="row-mon">{d.toLocaleString(t.dateLocale, { month: "short" }).toUpperCase()}</span>
              <span class="row-yr">{d.getFullYear()}</span>
            </div>
            <div class="row-thumb">
              {img ? (
                <img src={thumb || img} alt={post.data.title} width="96" height="54" loading="lazy" decoding="async" />
              ) : (
                <div class="row-thumb-empty" />
              )}
            </div>
            <div class="row-body">
              <div class="row-meta">
                {tag && <span class="row-tag">{tag.name}</span>}
                <span class="row-read">{t.readingTimeLabel(readingTime)}</span>
              </div>
              <h3 class="row-title">{post.data.title}</h3>
            </div>
            <svg class="row-arrow" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
          </a>
        );
      })}
    </div>
    <p class="no-results" id="no-results" style="display:none;">{t.noResults}</p>
  </section>

</BaseLayout>

<!-- ═══ CAROUSEL JS ═══ -->
<script>
  const track = document.getElementById('carousel-track') as HTMLElement;
  const dots = document.querySelectorAll<HTMLElement>('.dot');
  const slides = document.querySelectorAll<HTMLElement>('.carousel-slide');
  const total = slides.length;
  let current = 0;

  function isMobile() { return window.innerWidth < 768; }
  function perPage() { return isMobile() ? 1 : 3; }
  function maxIdx() { return Math.max(0, total - perPage()); }

  function goTo(idx: number) {
    current = Math.max(0, Math.min(idx, maxIdx()));
    const slideEl = slides[0] as HTMLElement | undefined;
    const gap = isMobile() ? 0 : 16; // matches CSS: gap:0 mobile, gap:1rem desktop
    const offset = slideEl ? (slideEl.offsetWidth + gap) * current : 0;
    track.style.transform = `translateX(-${offset}px)`;
    dots.forEach((d, i) => d.classList.toggle('active', i === current));
  }

  document.getElementById('carousel-prev')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('carousel-next')?.addEventListener('click', () => goTo(current + 1));
  dots.forEach((d) => d.addEventListener('click', () => goTo(Number(d.dataset.dot))));

  let startX = 0;
  track.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', (e) => {
    const dx = e.changedTouches[0].clientX - startX;
    if (Math.abs(dx) > 40) goTo(current + (dx < 0 ? 1 : -1));
  }, { passive: true });

  window.addEventListener('resize', () => { goTo(Math.min(current, maxIdx())); });
</script>

<!-- ═══ FILTER JS ═══ -->
<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
  const rows = document.querySelectorAll<HTMLElement>('.post-row');
  const noResults = document.getElementById('no-results');

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      const filter = pill.dataset.filter!;
      pills.forEach((p) => p.classList.remove('active'));
      pill.classList.add('active');
      let visible = 0;
      rows.forEach((row) => {
        const tags = row.dataset.tags?.split(',') || [];
        const show = filter === 'all' || tags.includes(filter);
        row.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (noResults) noResults.style.display = visible === 0 ? '' : 'none';
    });
  });
</script>

<style>
  /* ─── Hero ──────────────────────────────────── */
  .hero {
    padding: 3rem 0 2rem;
    text-align: center;
  }

  .hero-label {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9ca3af;
    margin: 0 0 0.75rem;
  }

  .hero-title {
    font-size: 2.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 0.5rem;
    background: linear-gradient(135deg, #111 0%, #555 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1rem;
    color: #6b7280;
    margin: 0;
  }

  /* ─── Carousel ─────────────────────────────── */
  .carousel-section {
    max-width: 960px;
    margin: 1.5rem auto 0;
    padding: 0 1rem;
  }

  .carousel-wrapper {
    overflow: hidden;
    border-radius: 0.75rem;
  }

  .carousel-track {
    display: flex;
    gap: 0; /* no gap on mobile — translateX(-slideWidth * n) works cleanly */
    transition: transform 0.45s cubic-bezier(0.77, 0, 0.175, 1);
  }

  .carousel-slide {
    flex: 0 0 100%;
    min-width: 0;
  }

  @media (min-width: 768px) {
    .carousel-track { gap: 1rem; }
    .carousel-slide { flex: 0 0 calc((100% - 2rem) / 3); }
    .carousel-dots { display: none; }
    .carousel-controls { padding-top: 0.875rem; }
  }

  .slide-link {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 0.75rem;
    overflow: hidden;
    background: #fff;
    border: 1px solid #f0f0f0;
    transition: box-shadow 0.2s, transform 0.2s;
    height: 100%;
  }

  .slide-link:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .slide-img-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #f3f4f6;
  }

  .slide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .slide-link:hover .slide-img { transform: scale(1.04); }

  .slide-img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
  }

  .slide-content {
    padding: 0.875rem 1rem 1rem;
  }

  .slide-tag {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9ca3af;
    margin-bottom: 0.3rem;
  }

  .slide-title {
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.4;
    margin: 0 0 0.4rem;
    color: #111827;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.15s;
  }

  .slide-link:hover .slide-title { color: #2563eb; }

  .slide-excerpt {
    font-size: 0.78rem;
    line-height: 1.6;
    color: #6b7280;
    margin: 0 0 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .slide-date { font-size: 0.7rem; color: #d1d5db; }

  .carousel-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 0.75rem 0 0;
  }

  .carousel-btn {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: 1px solid #e5e7eb;
    background: #fff;
    color: #374151;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, border-color 0.15s;
  }

  .carousel-btn:hover { background: #f3f4f6; border-color: #d1d5db; }

  .carousel-dots { display: flex; gap: 0.35rem; align-items: center; }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: none;
    background: #d1d5db;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, width 0.2s;
  }

  .dot.active { background: #111827; width: 16px; border-radius: 3px; }

  /* ─── Filter ───────────────────────────────── */
  .filter-wrap {
    position: sticky;
    top: 0;
    z-index: 30;
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid #f0f0f0;
    padding: 0.6rem 0;
    margin-top: 1.75rem;
  }

  .filter-bar {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    gap: 0.4rem;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .filter-bar::-webkit-scrollbar { display: none; }

  .filter-pill {
    flex-shrink: 0;
    padding: 0.28rem 0.8rem;
    border-radius: 999px;
    border: 1px solid #e5e7eb;
    background: #fff;
    font-size: 0.75rem;
    color: #6b7280;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
    line-height: 1.6;
  }

  .filter-pill:hover { border-color: #d1d5db; color: #374151; }
  .filter-pill.active { background: #0f172a; border-color: #0f172a; color: #fff; }

  /* ─── Compact List ─────────────────────────── */
  .post-list-section {
    max-width: 960px;
    margin: 0 auto;
    padding: 0.5rem 1rem 3rem;
  }

  .post-list { display: flex; flex-direction: column; }

  .post-row {
    display: grid;
    grid-template-columns: 3rem 6rem 1fr 1rem;
    align-items: center;
    gap: 0.75rem;
    padding: 0.7rem 0.5rem;
    border-bottom: 1px solid #f3f4f6;
    text-decoration: none;
    color: inherit;
    border-radius: 0.375rem;
    margin: 0 -0.5rem;
    transition: background 0.15s;
  }

  .post-row:hover { background: #fafafa; }
  .post-row:first-child { border-top: 1px solid #f3f4f6; }

  .row-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex-shrink: 0;
  }

  .row-day { font-size: 1.05rem; font-weight: 700; color: #111827; line-height: 1; }
  .row-mon { font-size: 0.58rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: #9ca3af; }
  .row-yr { font-size: 0.58rem; color: #d1d5db; }

  .row-thumb {
    width: 6rem;
    aspect-ratio: 16 / 9;
    border-radius: 0.35rem;
    overflow: hidden;
    background: #f3f4f6;
    flex-shrink: 0;
  }

  .row-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .post-row:hover .row-thumb img { transform: scale(1.05); }
  .row-thumb-empty { width: 100%; height: 100%; background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%); }

  .row-body { min-width: 0; }

  .row-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.2rem; }

  .row-tag { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.09em; text-transform: uppercase; color: #9ca3af; }

  .row-read { font-size: 0.6rem; color: #d1d5db; }

  .row-title {
    font-size: 0.88rem;
    font-weight: 650;
    line-height: 1.4;
    margin: 0;
    color: #111827;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 0.15s;
  }

  .post-row:hover .row-title { color: #2563eb; }

  .row-arrow {
    color: #d1d5db;
    flex-shrink: 0;
    transition: color 0.15s, transform 0.15s;
  }

  .post-row:hover .row-arrow { color: #2563eb; transform: translateX(2px); }

  @media (max-width: 480px) {
    .post-row { grid-template-columns: 2.5rem 5rem 1fr 1rem; gap: 0.5rem; }
    .row-thumb { width: 5rem; }
    .row-title { font-size: 0.82rem; }
  }

  .no-results {
    text-align: center;
    color: #9ca3af;
    padding: 3rem 0;
    font-size: 0.95rem;
  }
</style>
