---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  excerpt: string;
  featureImage: string | null;
  publishedAt: string;
  tags: { name: string; slug: string }[];
  lang: "zh-tw" | "en";
  pairSlug: string | null;
  pairLang: "zh-tw" | "en" | null;
  readingTime: number;
}

const {
  title,
  excerpt,
  featureImage,
  publishedAt,
  tags,
  lang,
  pairSlug,
  pairLang,
  readingTime,
} = Astro.props;

const date = new Date(publishedAt);
const day = date.getDate().toString().padStart(2, "0");
const month = date.toLocaleString("en-US", { month: "short" }).toUpperCase();
const year = date.getFullYear();
const formattedDate = `${day} ${month} ${year}`;

const pairUrl = pairSlug
  ? pairLang === "en"
    ? `/en/${pairSlug}/`
    : `/zh-tw/${pairSlug}/`
  : null;

const siteUrl = "https://reallyniceday.com";
const canonicalUrl = lang === "en"
  ? `${siteUrl}/en/${Astro.params.slug}/`
  : `${siteUrl}/zh-tw/${Astro.params.slug}/`;
const alternateUrl = pairUrl ? `${siteUrl}${pairUrl}` : undefined;
const alternateLang = pairLang === "en" ? "en" : pairLang === "zh-tw" ? "zh-Hant-TW" : undefined;
---

<BaseLayout
  title={`${title} | ReallyNiceDay`}
  description={excerpt}
  ogImage={featureImage}
  lang={lang}
  canonicalUrl={canonicalUrl}
  alternateUrl={alternateUrl}
  alternateLang={alternateLang}
>
  <!-- Reading progress bar -->
  <div id="progress-bar" class="fixed top-0 left-0 h-1 bg-blue-500 z-50 transition-[width] duration-100" style="width: 0%"></div>

  <!-- TOC sidebar — fixed left -->
  <aside class="gh-sidebar">
    <div class="gh-toc"></div>
  </aside>

  <article class="mx-auto max-w-3xl px-4 py-8">
    <header class="mb-8 text-center">
      <!-- Meta row: date · reading time · tag -->
      <div class="flex items-center justify-center gap-2 text-xs tracking-widest text-gray-400 uppercase mb-4">
        <time datetime={publishedAt}>{formattedDate}</time>
        <span>·</span>
        <span>{readingTime} {lang === "en" ? "MIN READ" : "分鐘閱讀"}</span>
        {tags.length > 0 && (
          <>
            <span>·</span>
            <span class="text-amber-700 font-semibold">{tags[0].name}</span>
          </>
        )}
        {pairUrl && (
          <>
            <span>·</span>
            <a href={pairUrl} class="text-gray-400 hover:text-gray-600 transition-colors normal-case tracking-normal">
              {pairLang === "en" ? "Read in English" : "閱讀中文版"}
            </a>
          </>
        )}
      </div>

      <!-- Title -->
      <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-5">
        {title}
      </h1>

      <!-- Excerpt -->
      {excerpt && (
        <p class="text-lg text-gray-500 leading-relaxed max-w-2xl mx-auto mb-8">
          {excerpt}
        </p>
      )}

      <!-- Feature image -->
      {featureImage && (
        <img
          src={featureImage}
          alt={title}
          class="w-full rounded-lg"
          width="768"
          height="432"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      )}
    </header>

    <div class="gh-content prose prose-lg max-w-none prose-img:rounded-lg prose-a:text-blue-600 prose-headings:font-bold">
      <slot />
    </div>
  </article>
</BaseLayout>

<script src="https://cdnjs.cloudflare.com/ajax/libs/tocbot/4.36.4/tocbot.min.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Init tocbot
    const content = document.querySelector('.gh-content');
    if (content && typeof (window as any).tocbot !== 'undefined') {
      (window as any).tocbot.init({
        tocSelector: '.gh-toc',
        contentSelector: '.gh-content',
        headingSelector: 'h2, h3, h4',
        hasInnerContainers: true,
        headingsOffset: 40,
        scrollSmoothOffset: -40,
        collapseDepth: 2,
      });
    }

    // Reading progress bar
    const progressBar = document.getElementById('progress-bar');
    if (progressBar) {
      window.addEventListener('scroll', () => {
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const scrolled = (window.scrollY / docHeight) * 100;
        progressBar.style.width = `${Math.min(scrolled, 100)}%`;
      });
    }
  });
</script>

<style>
  /* TOC sidebar — fixed on left, desktop only */
  .gh-sidebar {
    display: none;
  }

  @media (min-width: 1280px) {
    .gh-sidebar {
      display: block;
      position: fixed;
      top: 5rem;
      left: max(1rem, calc((100vw - 48rem) / 2 - 16rem - 2rem));
      width: 14rem;
      max-height: calc(100vh - 6rem);
      overflow-y: auto;
    }
  }

  /* TOC — counter-based numbering: 1. / a. / i. */
  .gh-toc :global(.toc-list) {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: toc-h2;
  }

  /* H2 level: 1. 2. 3. */
  .gh-toc > :global(.toc-list) > :global(.toc-list-item) {
    counter-increment: toc-h2;
  }
  .gh-toc > :global(.toc-list) > :global(.toc-list-item) > :global(.toc-link::before) {
    content: counter(toc-h2) ". ";
  }

  /* H3 level: a. b. c. */
  .gh-toc :global(.toc-list .toc-list) {
    counter-reset: toc-h3;
    padding-left: 0.9rem;
    margin-top: 0.15rem;
  }
  .gh-toc :global(.toc-list .toc-list > .toc-list-item) {
    counter-increment: toc-h3;
  }
  .gh-toc :global(.toc-list .toc-list > .toc-list-item > .toc-link::before) {
    content: counter(toc-h3, lower-alpha) ". ";
  }

  /* H4 level: i. ii. iii. */
  .gh-toc :global(.toc-list .toc-list .toc-list) {
    counter-reset: toc-h4;
    padding-left: 0.9rem;
  }
  .gh-toc :global(.toc-list .toc-list .toc-list > .toc-list-item) {
    counter-increment: toc-h4;
  }
  .gh-toc :global(.toc-list .toc-list .toc-list > .toc-list-item > .toc-link::before) {
    content: counter(toc-h4, lower-roman) ". ";
  }

  .gh-toc :global(.toc-list-item) {
    margin-bottom: 0.2rem;
  }

  .gh-toc :global(.toc-link) {
    display: block;
    font-size: 0.75rem;
    line-height: 1.5;
    color: #9ca3af;
    text-decoration: none;
    padding: 0.1rem 0;
    transition: color 0.15s;
  }

  .gh-toc :global(.toc-link:hover) {
    color: #374151;
  }

  .gh-toc :global(.is-active-link) {
    color: #111827;
    font-weight: 600;
  }

  /* Collapse H4 lists unless active */
  .gh-toc :global(.is-collapsible) {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.2s ease;
  }

  .gh-toc :global(.is-collapsible:not(.is-collapsed)) {
    max-height: 999px;
  }
</style>
