---
import { readFileSync, existsSync } from "node:fs";
import { marked } from "marked";
import { getCollection, render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const zhSlugs = new Set(posts.filter((p) => p.data.lang === "zh-tw").map((p) => p.data.slug));
  const enSlugs = new Set(posts.filter((p) => p.data.lang === "en").map((p) => p.data.slug));

  return posts.map((post) => {
    const { slug, lang } = post.data;
    let pairSlug: string | null = null;
    let pairLang: "zh-tw" | "en" | null = null;

    if (lang === "zh-tw") {
      // New posts: same slug. Legacy: en slug has "-en" suffix.
      if (enSlugs.has(slug)) { pairSlug = slug; pairLang = "en"; }
      else if (enSlugs.has(slug + "-en")) { pairSlug = slug + "-en"; pairLang = "en"; }
    } else {
      // New posts: same slug. Legacy: strip "-en" suffix to find zh-tw pair.
      if (zhSlugs.has(slug)) { pairSlug = slug; pairLang = "zh-tw"; }
      else if (slug.endsWith("-en") && zhSlugs.has(slug.replace(/-en$/, ""))) {
        pairSlug = slug.replace(/-en$/, ""); pairLang = "zh-tw";
      }
    }

    // Frontmatter pair_slug takes priority if explicitly set
    if (post.data.pair_slug) { pairSlug = post.data.pair_slug; pairLang = post.data.pair_lang; }

    return { params: { lang, slug }, props: { post, pairSlug, pairLang } };
  });
}

const { post, pairSlug, pairLang } = Astro.props;
const { title, excerpt, feature_image, published_at, updated_at, tags, lang } = post.data;
const { slug } = post.data;

const mdxFile = `src/content/posts/${lang}/${slug}.mdx`;
const isMdx = existsSync(mdxFile);

let Content: any = null;
let htmlContent = "";
let readingTime = 1;

if (isMdx) {
  const rendered = await render(post);
  Content = rendered.Content;
  const raw = readFileSync(mdxFile, "utf-8");
  const body = raw.replace(/^---\n[\s\S]*?\n---\n?/, "").trim();
  const text = body.replace(/<[^>]+>/g, " ").replace(/[#*`_[\]()!]/g, " ").replace(/\s+/g, " ").trim();
  readingTime = lang === "zh-tw"
    ? Math.max(1, Math.round(text.length / 300))
    : Math.max(1, Math.round(text.split(" ").length / 200));
} else {
  // Read raw file to bypass Astro's Markdown pipeline that corrupts Ghost HTML
  const raw = readFileSync(`src/content/posts/${lang}/${slug}.md`, "utf-8");
  const body = raw.replace(/^---\n[\s\S]*?\n---\n?/, "").trim();
  // Auto-detect: Ghost-migrated posts start with "<" (raw HTML); new posts use Markdown
  const rawHtml = body.startsWith("<") ? body : await marked(body);
  // Demote H1 tags in the content body to H2 — the page <h1> is the post title
  htmlContent = rawHtml.replace(/<h1(\s|>)/gi, "<h2$1").replace(/<\/h1>/gi, "</h2>");
  const text = htmlContent.replace(/<[^>]+>/g, " ").replace(/\s+/g, " ").trim();
  readingTime = lang === "zh-tw"
    ? Math.max(1, Math.round(text.length / 300))
    : Math.max(1, Math.round(text.split(" ").length / 200));
}
---

<PostLayout
  title={title}
  excerpt={excerpt}
  featureImage={feature_image}
  publishedAt={published_at}
  updatedAt={updated_at}
  tags={tags}
  lang={lang}
  pairSlug={pairSlug}
  pairLang={pairLang}
  readingTime={readingTime}
>
  {isMdx ? <Content /> : <Fragment set:html={htmlContent} />}
</PostLayout>
