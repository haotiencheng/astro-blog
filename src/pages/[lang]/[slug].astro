---
import { marked } from "marked";

// Add id attributes to headings so tocbot can link to them.
// text is raw inline markdown in marked v17, so we parseInline to render
// inline code, bold, etc., and strip markdown syntax for the ID.
marked.use({
  renderer: {
    heading({ text, depth }: { text: string; depth: number }) {
      const rendered = marked.parseInline(text) as string;
      const rawText = text
        .replace(/`([^`]*)`/g, "$1")   // strip backtick code markers
        .replace(/[*_~]/g, "")          // strip bold/italic/strike markers
        .replace(/<[^>]+>/g, "");       // strip any remaining HTML
      const id = rawText
        .toLowerCase()
        .replace(/[^\w\u4e00-\u9fff]+/g, "-")
        .replace(/^-+|-+$/g, "");
      return `<h${depth} id="${id}">${rendered}</h${depth}>\n`;
    },
  },
});
import { getCollection, render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";

// Detect MDX files at build time via Vite — no runtime fs needed
const mdxFiles = new Set(
  Object.keys(import.meta.glob("/src/content/posts/**/*.mdx"))
    .map((p) => p.replace("/src/content/posts/", "").replace(".mdx", "")),
);

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const zhSlugs = new Set(posts.filter((p) => p.data.lang === "zh-tw").map((p) => p.data.slug));
  const enSlugs = new Set(posts.filter((p) => p.data.lang === "en").map((p) => p.data.slug));

  return posts.map((post) => {
    const { slug, lang } = post.data;
    let pairSlug: string | null = null;
    let pairLang: "zh-tw" | "en" | null = null;

    if (lang === "zh-tw") {
      // New posts: same slug. Legacy: en slug has "-en" suffix.
      if (enSlugs.has(slug)) { pairSlug = slug; pairLang = "en"; }
      else if (enSlugs.has(slug + "-en")) { pairSlug = slug + "-en"; pairLang = "en"; }
    } else {
      // New posts: same slug. Legacy: strip "-en" suffix to find zh-tw pair.
      if (zhSlugs.has(slug)) { pairSlug = slug; pairLang = "zh-tw"; }
      else if (slug.endsWith("-en") && zhSlugs.has(slug.replace(/-en$/, ""))) {
        pairSlug = slug.replace(/-en$/, ""); pairLang = "zh-tw";
      }
    }

    // Frontmatter pair_slug takes priority if explicitly set
    if (post.data.pair_slug) { pairSlug = post.data.pair_slug; pairLang = post.data.pair_lang; }

    return { params: { lang, slug }, props: { post, pairSlug, pairLang } };
  });
}

const { post, pairSlug, pairLang } = Astro.props;
const { title, excerpt, feature_image, published_at, updated_at, tags, lang } = post.data;
const { slug } = post.data;

// Related posts: same language, share at least one tag, exclude current post
const allPosts = await getCollection("posts");
const currentTagSlugs = new Set(tags.map((t: { slug: string }) => t.slug));
const relatedPosts = allPosts
  .filter((p) => p.data.lang === lang && p.data.slug !== slug)
  .map((p) => ({
    post: p,
    score: p.data.tags.filter((t) => currentTagSlugs.has(t.slug)).length,
  }))
  .filter((p) => p.score > 0)
  .sort((a, b) => b.score - a.score || new Date(b.post.data.published_at).getTime() - new Date(a.post.data.published_at).getTime())
  .slice(0, 3)
  .map((p) => p.post);

// Use post.body from content collection — no readFileSync needed
const body = (post.body ?? "").trim();
const isMdx = mdxFiles.has(`${lang}/${slug}`);

let Content: any = null;
let htmlContent = "";
let readingTime = 1;

if (isMdx) {
  const rendered = await render(post);
  Content = rendered.Content;
  const text = body.replace(/<[^>]+>/g, " ").replace(/[#*`_[\]()!]/g, " ").replace(/\s+/g, " ").trim();
  readingTime = lang === "zh-tw"
    ? Math.max(1, Math.round(text.length / 300))
    : Math.max(1, Math.round(text.split(" ").length / 200));
} else {
  // Auto-detect: Ghost-migrated posts start with "<" (raw HTML); new posts use Markdown
  const rawHtml = body.startsWith("<") ? body : await marked(body);
  // Demote H1 tags in the content body to H2 — the page <h1> is the post title
  htmlContent = rawHtml.replace(/<h1(\s|>)/gi, "<h2$1").replace(/<\/h1>/gi, "</h2>");
  const text = htmlContent.replace(/<[^>]+>/g, " ").replace(/\s+/g, " ").trim();
  readingTime = lang === "zh-tw"
    ? Math.max(1, Math.round(text.length / 300))
    : Math.max(1, Math.round(text.split(" ").length / 200));
}
---

<PostLayout
  title={title}
  excerpt={excerpt}
  featureImage={feature_image}
  publishedAt={published_at}
  updatedAt={updated_at}
  tags={tags}
  lang={lang}
  slug={slug}
  pairSlug={pairSlug}
  pairLang={pairLang}
  readingTime={readingTime}
  relatedPosts={relatedPosts}
>
  {isMdx ? <Content /> : <Fragment set:html={htmlContent} />}
</PostLayout>
