---
import { readFileSync } from "node:fs";
import { marked } from "marked";
import { getCollection } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const zhSlugs = new Set(
    posts.filter((p) => p.data.lang === "zh-tw").map((p) => p.data.slug)
  );

  return posts
    .filter((p) => p.data.lang === "en")
    .map((post) => {
      // Auto-detect pair: same slug (new convention) or strip "-en" suffix (legacy)
      let pairSlug: string | null = null;
      let pairLang: "zh-tw" | "en" | null = null;
      if (zhSlugs.has(post.data.slug)) {
        pairSlug = post.data.slug;
        pairLang = "zh-tw";
      } else if (post.data.slug.endsWith("-en") && zhSlugs.has(post.data.slug.replace(/-en$/, ""))) {
        pairSlug = post.data.slug.replace(/-en$/, "");
        pairLang = "zh-tw";
      }
      // Frontmatter pair_slug takes priority if explicitly set
      if (post.data.pair_slug) {
        pairSlug = post.data.pair_slug;
        pairLang = post.data.pair_lang;
      }

      return {
        params: { slug: post.data.slug },
        props: { post, pairSlug, pairLang },
      };
    });
}

const { post, pairSlug, pairLang } = Astro.props;
const { title, excerpt, feature_image, published_at, tags, lang } = post.data;

// Read raw file to bypass Astro's Markdown pipeline that corrupts Ghost HTML
const raw = readFileSync(`src/content/posts/${post.data.slug}.md`, "utf-8");
const body = raw.replace(/^---\n[\s\S]*?\n---\n?/, "").trim();
// Auto-detect: Ghost-migrated posts start with "<" (raw HTML); new posts use Markdown
const htmlContent = body.startsWith("<") ? body : await marked(body);
---

<PostLayout
  title={title}
  excerpt={excerpt}
  featureImage={feature_image}
  publishedAt={published_at}
  tags={tags}
  lang={lang}
  pairSlug={pairSlug}
  pairLang={pairLang}
>
  <Fragment set:html={htmlContent} />
</PostLayout>
