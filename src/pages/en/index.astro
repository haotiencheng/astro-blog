---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";

const allPosts = await getCollection("posts");
const enPosts = allPosts
  .filter((p) => p.data.lang === "en")
  .sort((a, b) => new Date(b.data.published_at).getTime() - new Date(a.data.published_at).getTime());

const featuredPosts = enPosts.filter((p) => p.data.featured);
const recentPosts = enPosts;
---

<BaseLayout title="ReallyNiceDay" lang="en">
  <div class="mx-auto max-w-3xl px-4 py-8">
    {
      featuredPosts.length > 0 && (
        <section class="mb-10">
          <h2 class="text-sm font-medium text-gray-400 uppercase tracking-wider mb-4">
            Featured
          </h2>
          {featuredPosts.map((post) => (
            <PostCard
              title={post.data.title}
              slug={post.data.slug}
              excerpt={post.data.excerpt}
              featureImage={post.data.feature_image}
              publishedAt={post.data.published_at}
              tags={post.data.tags}
              lang={post.data.lang}
              featured
            />
          ))}
        </section>
      )
    }

    <section>
      <h2 class="text-sm font-medium text-gray-400 uppercase tracking-wider mb-4">
        All Posts
      </h2>
      {
        recentPosts.map((post) => (
          <PostCard
            title={post.data.title}
            slug={post.data.slug}
            excerpt={post.data.excerpt}
            featureImage={post.data.feature_image}
            publishedAt={post.data.published_at}
            tags={post.data.tags}
            lang={post.data.lang}
          />
        ))
      }
    </section>
  </div>
</BaseLayout>
