---
import { getCollection } from "astro:content";
import HomepageLayout from "../layouts/HomepageLayout.astro";
import { ui } from "../i18n/homepage";

const allPosts = await getCollection("posts");
const langPosts = allPosts
  .filter((p) => p.data.lang === "zh-tw")
  .sort((a, b) => new Date(b.data.published_at).getTime() - new Date(a.data.published_at).getTime());

const featured = langPosts.filter((p) => p.data.featured);
const carouselPosts = featured.length > 0 ? featured : langPosts.slice(0, 3);

const tagMap = new Map<string, string>();
for (const p of langPosts) for (const tag of p.data.tags) tagMap.set(tag.slug, tag.name);
const allTags = Array.from(tagMap.entries()).map(([slug, name]) => ({ slug, name }));
---

<HomepageLayout
  lang="zh-tw"
  carouselPosts={carouselPosts}
  allPosts={langPosts}
  allTags={allTags}
  t={ui["zh-tw"]}
/>
