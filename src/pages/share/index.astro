---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Share" noindex={true}>
  <!-- Editor view -->
  <div id="editor-view" class="mx-auto max-w-3xl px-4 py-10">
    <h1 class="text-2xl font-bold mb-6">Share Markdown</h1>
    <div class="flex flex-col gap-3 mb-4">
      <input
        id="share-title"
        type="text"
        class="w-full p-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-400"
        placeholder="Title (for link preview)"
      />
      <input
        id="share-desc"
        type="text"
        class="w-full p-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-400"
        placeholder="Description (for link preview)"
      />
    </div>
    <textarea
      id="md-input"
      class="w-full h-[50vh] p-4 border border-gray-300 rounded-lg font-mono text-sm resize-y focus:outline-none focus:ring-2 focus:ring-gray-400"
      placeholder="Paste your markdown here..."
    ></textarea>
    <div class="mt-4 flex gap-3">
      <button
        id="btn-preview"
        class="px-4 py-2 bg-gray-900 text-white rounded-lg hover:bg-gray-700 transition-colors text-sm"
      >
        Preview
      </button>
      <button
        id="btn-share"
        class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-100 transition-colors text-sm"
      >
        Generate Share Link
      </button>
    </div>
    <div id="share-result" class="mt-4 hidden">
      <div class="flex items-center gap-2">
        <input
          id="share-url"
          type="text"
          readonly
          class="flex-1 p-2 border border-gray-300 rounded-lg text-sm bg-gray-50"
        />
        <button
          id="btn-copy"
          class="px-3 py-2 bg-gray-900 text-white rounded-lg hover:bg-gray-700 transition-colors text-sm whitespace-nowrap"
        >
          Copy
        </button>
      </div>
    </div>

    <!-- Share list -->
    <div id="share-list" class="mt-12">
      <h2 class="text-lg font-semibold mb-4">My Shares</h2>
      <div id="share-list-content" class="text-sm text-gray-500">Loading...</div>
    </div>
  </div>

  <!-- Rendered view -->
  <div id="render-view" class="mx-auto max-w-3xl px-4 py-10 hidden">
    <div class="mb-6 flex items-center gap-3">
      <button
        id="btn-edit"
        class="px-3 py-1.5 border border-gray-300 rounded-lg hover:bg-gray-100 transition-colors text-sm"
      >
        &larr; Edit
      </button>
      <button
        id="btn-copy-render"
        class="px-3 py-1.5 border border-gray-300 rounded-lg hover:bg-gray-100 transition-colors text-sm hidden"
      >
        Copy Link
      </button>
    </div>
    <article id="rendered-content" class="prose prose-lg max-w-none gh-content"></article>
  </div>
</BaseLayout>

<script>
  import { marked } from "marked";

  marked.use({
    renderer: {
      heading({ text, depth }: { text: string; depth: number }) {
        const rendered = marked.parseInline(text) as string;
        const rawText = text
          .replace(/`([^`]*)`/g, "$1")
          .replace(/[*_~]/g, "")
          .replace(/<[^>]+>/g, "");
        const id = rawText
          .toLowerCase()
          .replace(/[^\w\u4e00-\u9fff]+/g, "-")
          .replace(/^-+|-+$/g, "");
        return `<h${depth} id="${id}">${rendered}</h${depth}>\n`;
      },
    },
  });

  const editorView = document.getElementById("editor-view")!;
  const renderView = document.getElementById("render-view")!;
  const mdInput = document.getElementById("md-input") as HTMLTextAreaElement;
  const titleInput = document.getElementById("share-title") as HTMLInputElement;
  const descInput = document.getElementById("share-desc") as HTMLInputElement;
  const renderedContent = document.getElementById("rendered-content")!;
  const shareResult = document.getElementById("share-result")!;
  const shareUrl = document.getElementById("share-url") as HTMLInputElement;
  const btnCopyRender = document.getElementById("btn-copy-render")!;
  const shareListContent = document.getElementById("share-list-content")!;

  let currentShareId: string | null = null;

  function renderMarkdown(md: string) {
    renderedContent.innerHTML = marked(md) as string;
  }

  function showView(view: "editor" | "render") {
    editorView.classList.toggle("hidden", view !== "editor");
    renderView.classList.toggle("hidden", view !== "render");
  }

  function formatDate(iso: string): string {
    const d = new Date(iso + "Z");
    return d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
  }

  // Load share list
  async function loadShareList() {
    try {
      const res = await fetch("/api/shares");
      const shares = await res.json() as { id: string; title: string; description: string; created_at: string }[];
      if (shares.length === 0) {
        shareListContent.textContent = "No shares yet.";
        return;
      }
      shareListContent.innerHTML = shares
        .map((s) => {
          const label = s.title || s.id;
          const desc = s.description ? `<span class="text-gray-400 ml-2">${s.description}</span>` : "";
          return `<div class="flex items-center justify-between py-2 border-b border-gray-100">
            <div class="min-w-0">
              <a href="/s/${s.id}" class="text-gray-900 hover:underline font-medium">${label}</a>${desc}
            </div>
            <div class="flex items-center gap-3 ml-4 shrink-0">
              <span class="text-gray-400 text-xs">${formatDate(s.created_at)}</span>
              <button data-copy-id="${s.id}" class="text-xs px-2 py-1 border border-gray-300 rounded hover:bg-gray-100 transition-colors">Copy</button>
            </div>
          </div>`;
        })
        .join("");

      // Attach copy handlers
      shareListContent.querySelectorAll("[data-copy-id]").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const id = (e.currentTarget as HTMLElement).dataset.copyId;
          const link = `${window.location.origin}/s/${id}`;
          navigator.clipboard.writeText(link);
          const el = e.currentTarget as HTMLButtonElement;
          el.textContent = "Copied!";
          setTimeout(() => (el.textContent = "Copy"), 1500);
        });
      });
    } catch {
      shareListContent.textContent = "Failed to load shares.";
    }
  }

  // Preview button
  document.getElementById("btn-preview")!.addEventListener("click", () => {
    if (!mdInput.value.trim()) return;
    renderMarkdown(mdInput.value);
    btnCopyRender.classList.add("hidden");
    showView("render");
  });

  // Generate share link
  document.getElementById("btn-share")!.addEventListener("click", async (e) => {
    if (!mdInput.value.trim()) return;
    const btn = e.target as HTMLButtonElement;
    btn.textContent = "Saving...";
    btn.disabled = true;

    try {
      const res = await fetch("/api/shares", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          markdown: mdInput.value,
          title: titleInput.value,
          description: descInput.value,
        }),
      });
      const data = await res.json() as { id: string };
      currentShareId = data.id;
      const link = `${window.location.origin}/s/${data.id}`;
      shareUrl.value = link;
      shareResult.classList.remove("hidden");
      loadShareList();
    } finally {
      btn.textContent = "Generate Share Link";
      btn.disabled = false;
    }
  });

  // Copy link buttons
  document.getElementById("btn-copy")!.addEventListener("click", (e) => {
    navigator.clipboard.writeText(shareUrl.value);
    const btn = e.target as HTMLButtonElement;
    btn.textContent = "Copied!";
    setTimeout(() => (btn.textContent = "Copy"), 1500);
  });

  btnCopyRender.addEventListener("click", (e) => {
    if (!currentShareId) return;
    const link = `${window.location.origin}/s/${currentShareId}`;
    navigator.clipboard.writeText(link);
    const btn = e.target as HTMLButtonElement;
    btn.textContent = "Copied!";
    setTimeout(() => (btn.textContent = "Copy Link"), 1500);
  });

  // Back to edit
  document.getElementById("btn-edit")!.addEventListener("click", () => {
    showView("editor");
  });

  // Load share list on page load
  loadShareList();
</script>
