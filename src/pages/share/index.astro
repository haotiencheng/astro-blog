---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Share" noindex={true}>
  <!-- Editor view -->
  <div id="editor-view" class="mx-auto max-w-3xl px-4 py-10">
    <h1 class="text-2xl font-bold mb-6">Share Markdown</h1>
    <textarea
      id="md-input"
      class="w-full h-[60vh] p-4 border border-gray-300 rounded-lg font-mono text-sm resize-y focus:outline-none focus:ring-2 focus:ring-gray-400"
      placeholder="Paste your markdown here..."
    ></textarea>
    <div class="mt-4 flex gap-3">
      <button
        id="btn-preview"
        class="px-4 py-2 bg-gray-900 text-white rounded-lg hover:bg-gray-700 transition-colors text-sm"
      >
        Preview
      </button>
      <button
        id="btn-share"
        class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-100 transition-colors text-sm"
      >
        Generate Share Link
      </button>
    </div>
    <div id="share-result" class="mt-4 hidden">
      <div class="flex items-center gap-2">
        <input
          id="share-url"
          type="text"
          readonly
          class="flex-1 p-2 border border-gray-300 rounded-lg text-sm bg-gray-50"
        />
        <button
          id="btn-copy"
          class="px-3 py-2 bg-gray-900 text-white rounded-lg hover:bg-gray-700 transition-colors text-sm whitespace-nowrap"
        >
          Copy
        </button>
      </div>
    </div>
  </div>

  <!-- Rendered view -->
  <div id="render-view" class="mx-auto max-w-3xl px-4 py-10 hidden">
    <div class="mb-6 flex items-center gap-3">
      <button
        id="btn-edit"
        class="px-3 py-1.5 border border-gray-300 rounded-lg hover:bg-gray-100 transition-colors text-sm"
      >
        &larr; Edit
      </button>
      <button
        id="btn-copy-render"
        class="px-3 py-1.5 border border-gray-300 rounded-lg hover:bg-gray-100 transition-colors text-sm hidden"
      >
        Copy Link
      </button>
    </div>
    <article id="rendered-content" class="prose prose-lg max-w-none gh-content"></article>
  </div>

  <!-- Loading state -->
  <div id="loading-view" class="mx-auto max-w-3xl px-4 py-20 text-center hidden">
    <p class="text-gray-500">Loading...</p>
  </div>

  <!-- Not found state -->
  <div id="notfound-view" class="mx-auto max-w-3xl px-4 py-20 text-center hidden">
    <p class="text-gray-500">Share not found.</p>
    <a href="/share/" class="text-sm text-gray-900 underline mt-2 inline-block">Create a new one</a>
  </div>
</BaseLayout>

<script>
  import { marked } from "marked";

  marked.use({
    renderer: {
      heading({ text, depth }: { text: string; depth: number }) {
        const rendered = marked.parseInline(text) as string;
        const rawText = text
          .replace(/`([^`]*)`/g, "$1")
          .replace(/[*_~]/g, "")
          .replace(/<[^>]+>/g, "");
        const id = rawText
          .toLowerCase()
          .replace(/[^\w\u4e00-\u9fff]+/g, "-")
          .replace(/^-+|-+$/g, "");
        return `<h${depth} id="${id}">${rendered}</h${depth}>\n`;
      },
    },
  });

  const editorView = document.getElementById("editor-view")!;
  const renderView = document.getElementById("render-view")!;
  const loadingView = document.getElementById("loading-view")!;
  const notfoundView = document.getElementById("notfound-view")!;
  const mdInput = document.getElementById("md-input") as HTMLTextAreaElement;
  const renderedContent = document.getElementById("rendered-content")!;
  const shareResult = document.getElementById("share-result")!;
  const shareUrl = document.getElementById("share-url") as HTMLInputElement;
  const btnCopyRender = document.getElementById("btn-copy-render")!;

  let currentShareId: string | null = null;

  function renderMarkdown(md: string) {
    renderedContent.innerHTML = marked(md) as string;
  }

  function showView(view: "editor" | "render" | "loading" | "notfound") {
    editorView.classList.toggle("hidden", view !== "editor");
    renderView.classList.toggle("hidden", view !== "render");
    loadingView.classList.toggle("hidden", view !== "loading");
    notfoundView.classList.toggle("hidden", view !== "notfound");
  }

  // Preview button
  document.getElementById("btn-preview")!.addEventListener("click", () => {
    if (!mdInput.value.trim()) return;
    renderMarkdown(mdInput.value);
    btnCopyRender.classList.add("hidden");
    showView("render");
  });

  // Generate share link
  document.getElementById("btn-share")!.addEventListener("click", async (e) => {
    if (!mdInput.value.trim()) return;
    const btn = e.target as HTMLButtonElement;
    btn.textContent = "Saving...";
    btn.disabled = true;

    try {
      const res = await fetch("/api/shares", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ markdown: mdInput.value }),
      });
      const data = await res.json() as { id: string };
      currentShareId = data.id;
      const link = `${window.location.origin}/s/${data.id}`;
      shareUrl.value = link;
      shareResult.classList.remove("hidden");
    } finally {
      btn.textContent = "Generate Share Link";
      btn.disabled = false;
    }
  });

  // Copy link buttons
  document.getElementById("btn-copy")!.addEventListener("click", (e) => {
    navigator.clipboard.writeText(shareUrl.value);
    const btn = e.target as HTMLButtonElement;
    btn.textContent = "Copied!";
    setTimeout(() => (btn.textContent = "Copy"), 1500);
  });

  btnCopyRender.addEventListener("click", (e) => {
    if (!currentShareId) return;
    const link = `${window.location.origin}/s/${currentShareId}`;
    navigator.clipboard.writeText(link);
    const btn = e.target as HTMLButtonElement;
    btn.textContent = "Copied!";
    setTimeout(() => (btn.textContent = "Copy Link"), 1500);
  });

  // Back to edit
  document.getElementById("btn-edit")!.addEventListener("click", () => {
    showView("editor");
  });

  // On load: check for ?id= param (redirected from /s/[id])
  const params = new URLSearchParams(window.location.search);
  const shareId = params.get("id");

  if (shareId) {
    showView("loading");
    fetch(`/api/shares/${shareId}`)
      .then((r) => {
        if (!r.ok) throw new Error("not found");
        return r.json() as Promise<{ markdown: string }>;
      })
      .then(({ markdown }) => {
        currentShareId = shareId;
        mdInput.value = markdown;
        renderMarkdown(markdown);
        btnCopyRender.classList.remove("hidden");
        showView("render");
      })
      .catch(() => {
        showView("notfound");
      });
  }
</script>
