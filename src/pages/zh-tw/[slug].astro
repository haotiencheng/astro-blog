---
import { readFileSync, existsSync } from "node:fs";
import { marked } from "marked";
import { getCollection, render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const enSlugs = new Set(
    posts.filter((p) => p.data.lang === "en").map((p) => p.data.slug)
  );

  return posts
    .filter((p) => p.data.lang === "zh-tw")
    .map((post) => {
      // Auto-detect pair: same slug (new convention) or slug + "-en" (legacy)
      let pairSlug: string | null = null;
      let pairLang: "zh-tw" | "en" | null = null;
      if (enSlugs.has(post.data.slug)) {
        pairSlug = post.data.slug;
        pairLang = "en";
      } else if (enSlugs.has(post.data.slug + "-en")) {
        pairSlug = post.data.slug + "-en";
        pairLang = "en";
      }
      // Frontmatter pair_slug takes priority if explicitly set
      if (post.data.pair_slug) {
        pairSlug = post.data.pair_slug;
        pairLang = post.data.pair_lang;
      }

      return {
        params: { slug: post.data.slug },
        props: { post, pairSlug, pairLang },
      };
    });
}

const { post, pairSlug, pairLang } = Astro.props;
const { title, excerpt, feature_image, published_at, updated_at, tags, lang } = post.data;

// MDX posts (new): use Astro's render() pipeline — supports components/HTML natively
// MD posts (legacy Ghost HTML): use readFileSync + set:html to bypass the Markdown pipeline
const isMdx = existsSync(`src/content/posts/${post.data.slug}.mdx`);

let Content: any = null;
let htmlContent = "";
let readingTime = 1;

if (isMdx) {
  const rendered = await render(post);
  Content = rendered.Content;
  // Reading time: strip frontmatter + markup from raw source
  const raw = readFileSync(`src/content/posts/${post.data.slug}.mdx`, "utf-8");
  const body = raw.replace(/^---\n[\s\S]*?\n---\n?/, "").trim();
  const textContent = body.replace(/<[^>]+>/g, " ").replace(/[#*`_[\]()!]/g, " ").replace(/\s+/g, " ").trim();
  readingTime = Math.max(1, Math.round(textContent.length / 300));
} else {
  // Read raw file to bypass Astro's Markdown pipeline that corrupts Ghost HTML
  const raw = readFileSync(`src/content/posts/${post.data.slug}.md`, "utf-8");
  const body = raw.replace(/^---\n[\s\S]*?\n---\n?/, "").trim();
  // Auto-detect: Ghost-migrated posts start with "<" (raw HTML); new posts use Markdown
  const rawHtml = body.startsWith("<") ? body : await marked(body);
  // Demote H1 tags in the content body to H2 — the page <h1> is the post title
  htmlContent = rawHtml.replace(/<h1(\s|>)/gi, '<h2$1').replace(/<\/h1>/gi, '</h2>');
  // Reading time: strip HTML tags, count chars, ~300 chars/min for zh-tw
  const textContent = htmlContent.replace(/<[^>]+>/g, " ").replace(/\s+/g, " ").trim();
  readingTime = Math.max(1, Math.round(textContent.length / 300));
}
---

<PostLayout
  title={title}
  excerpt={excerpt}
  featureImage={feature_image}
  publishedAt={published_at}
  updatedAt={updated_at}
  tags={tags}
  lang={lang}
  pairSlug={pairSlug}
  pairLang={pairLang}
  readingTime={readingTime}
>
  {isMdx ? <Content /> : <Fragment set:html={htmlContent} />}
</PostLayout>
